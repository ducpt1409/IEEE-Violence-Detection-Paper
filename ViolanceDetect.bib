}

@article{nguyen_multistage_2021,
  title        = {Multistage Real-Time Fire Detection Using Convolutional Neural Networks and Long Short-Term Memory Networks},
  volume       = {9},
  issn         = {2169-3536},
  url          = {https://ieeexplore.ieee.org/abstract/document/9584840},
  doi          = {10.1109/ACCESS.2021.3122346},
  abstract     = {Fire is one of the most commonly occurring disasters and is the main cause of catastrophic personal injury and devastating property damage. An early detection system is necessary to prevent fires from spreading out of control. In this paper, we propose a multistage fire detection method using convolutional neural networks ({CNNs}) and long short-term memory ({LSTM}) networks. In the first stage, fire candidates are detected by using their salient features, such as their color, flickering frequency, and brightness. In the second stage, a pretrained {CNN} model is used to extract the 2D features of flames that are the input for the {LSTM} network. In the last stage, a softmax classifier is utilized to determine whether the flames represent a true fire or a nonfire moving object. The experimental results show that our proposed method can achieve competitive performance compared with other state-of-the-art methods and is suitable for real-world applications.},
  pages        = {146667--146679},
  journaltitle = {{IEEE} Access},
  author       = {Nguyen, Manh Dung and Vu, Hoai Nam and Pham, Duc Cuong and Choi, Bokgil and Ro, Soonghwan},
  urldate      = {2026-02-03},
  date         = {2021},
  keywords     = {Feature extraction, Computer architecture, convolutional neural network, Deep learning, Fire detection, Heuristic algorithms, Image color analysis, {ImageNet}, long short-term memory, Machine learning algorithms, Microprocessors},
  file         = {Full Text PDF:C\:\\Users\\LEGION\\Zotero\\storage\\YAKHYRKF\\Nguyen et al. - 2021 - Multistage Real-Time Fire Detection Using Convolutional Neural Networks and Long Short-Term Memory N.pdf:application/pdf}
}

